# Copy to .env and fill in your values:
#   cp .env.example .env

# Groq LLM (required for AI rankings and agent planner)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# OpenAI-compatible endpoint (default shown)
GROQ_API_BASE_URL=https://api.groq.com/openai/v1

# FastAPI server
API_HOST=127.0.0.1
API_PORT=8001

# Session memory (max conversation turns kept per session)
MAX_SESSION_TURNS=10
